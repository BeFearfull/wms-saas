# ===================================
# Backend Environment Variables
# ===================================

# Server Configuration
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/api

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wms_saas
DB_USERNAME=postgres
DB_PASSWORD=your_secure_password
DB_DRIVER=org.postgresql.Driver
DB_DIALECT=org.hibernate.dialect.PostgreSQLDialect

# JPA/Hibernate Configuration
JPA_HIBERNATE_DDL_AUTO=validate
JPA_SHOW_SQL=false
JPA_PROPERTIES_HIBERNATE_FORMAT_SQL=true

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production_at_least_32_characters
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Email Configuration (For Notifications)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=noreply@wms-saas.com
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true

# SMS Configuration (For Notifications)
SMS_PROVIDER=twilio
SMS_API_KEY=your_sms_api_key
SMS_API_SECRET=your_sms_api_secret
SMS_FROM_NUMBER=+91xxxxxxxxxx

# Application Configuration
APP_NAME=WMS-SaaS
APP_VERSION=1.0.0
APP_ENVIRONMENT=development
APP_TIMEZONE=Asia/Kolkata
APP_CURRENCY=INR

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=*
CORS_MAX_AGE=3600

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/wms-saas.log

# AWS Configuration (Optional)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=wms-saas-bucket

# ===================================
# Frontend Environment Variables
# ===================================

# API Configuration
VITE_API_BASE_URL=http://localhost:8080/api
VITE_API_TIMEOUT=10000

# Google OAuth
VITE_GOOGLE_CLIENT_ID=your_google_client_id

# App Configuration
VITE_APP_NAME=WMS-SaaS
VITE_APP_VERSION=1.0.0
VITE_TIMEZONE=Asia/Kolkata
VITE_CURRENCY=INR
VITE_CURRENCY_SYMBOL=₹

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_GOOGLE_LOGIN=true