# Backend Configuration
SPRING_PROFILE_ACTIVE=dev
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/api

# Database
DATABASE_URL=jdbc:postgresql://localhost:5432/wms_saas
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_password
DATABASE_DRIVER=org.postgresql.Driver

# JPA/Hibernate
JPA_DATABASE_PLATFORM=org.hibernate.dialect.PostgreSQL10Dialect
JPA_HIBERNATE_DDL_AUTO=validate
JPA_SHOW_SQL=false

# JWT
JWT_SECRET_KEY=your_super_secret_jwt_key_min_256_bits_long
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your_google_client_secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/api/v1/auth/google/callback

# Application
APP_NAME=WMS-SaaS
APP_VERSION=1.0.0
APP_TIMEZONE=Asia/Kolkata
APP_CURRENCY=INR

# Email Configuration
MAIL_SMTP_HOST=smtp.gmail.com
MAIL_SMTP_PORT=587
MAIL_SMTP_USERNAME=your_email@gmail.com
MAIL_SMTP_PASSWORD=your_app_password
MAIL_FROM=noreply@wms-saas.com

# SMS Configuration (optional)
SMS_PROVIDER=twilio
SMS_ACCOUNT_SID=your_twilio_account_sid
SMS_AUTH_TOKEN=your_twilio_auth_token
SMS_FROM_NUMBER=+91xxxxxxxxxx

# Frontend
REACT_APP_API_BASE_URL=http://localhost:8080/api
REACT_APP_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# AWS Configuration (if deploying to AWS)
AWS_REGION=ap-south-1
AWS_S3_BUCKET=wms-saas-bucket
AWS_RDS_ENDPOINT=wms-saas-db.xxxxx.ap-south-1.rds.amazonaws.com

# Azure Configuration (if deploying to Azure)
AZURE_SUBSCRIPTION_ID=your_subscription_id
AZURE_RESOURCE_GROUP=wms-saas
AZURE_STORAGE_ACCOUNT=wmssaasstg

# Logging
LOG_LEVEL=INFO
LOG_PATH=/var/log/wms-saas

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=100
